# ══════════════════════════════════════════════════════════════════════════════
# Kami-Sama Bot — Development Image
# ══════════════════════════════════════════════════════════════════════════════
FROM node:22-alpine

RUN apk add --no-cache \
    ca-certificates \
    tzdata \
    curl \
    bash \
    openssl \
    postgresql-client

WORKDIR /app

# ── Package.json & Installation des dépendances ──────────────────────────────
COPY package.json ./
RUN npm install --no-audit --no-fund

# ── Prisma Schema ────────────────────────────────────────────────────────────
COPY prisma/ ./prisma/
RUN npx prisma generate --schema=./prisma/schema.prisma

# ── Source du bot ─────────────────────────────────────────────────────────────
COPY . .

# ── Point d'entrée ───────────────────────────────────────────────────────────
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV NODE_ENV=development

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bot"]
