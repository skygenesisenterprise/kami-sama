generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  emailNormalized   String    @unique @map("email_normalized")
  displayName       String    @map("display_name")
  avatarUrl         String?   @map("avatar_url")
  status            String    @default("active")
  presenceStatus    String    @default("offline") @map("presence_status")
  lastSeenAt        DateTime? @map("last_seen_at")
  emailVerifiedAt   DateTime? @map("email_verified_at")
  passwordChangedAt DateTime? @map("password_changed_at")
  disabledAt        DateTime? @map("disabled_at")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  settings                UserSettings?
  notificationPreferences NotificationPreference?
  localCredentials        LocalCredential[]
  authAccounts            AuthAccount[]
  authSessions            AuthSession[]
  workspacesOwned         Workspace[]            @relation("WorkspaceOwner")
  workspaceMemberships    WorkspaceMember[]
  contacts                Contact[]              @relation("ContactOwner")
  familyMembers           FamilyMember[]         @relation("FamilyMemberUser")
  familyMembersInvited    FamilyMember[]         @relation("FamilyMemberInviter")
  invitationsSent         Invitation[]           @relation("InvitationSender")
  files                   FileItem[]
  billingInfo             BillingInfo?
  subscriptions           Subscription[]
  transactions            Transaction[]
  privacySettings         PrivacySettings?
  devices                 Device[]
  loginHistory            LoginHistory[]
  activities              ActivityItem[]

  @@index([status, lastSeenAt])
  @@map("users")
}

model UserSettings {
  id            String  @id @default(uuid())
  userId        String  @unique @map("user_id")
  theme         String  @default("system")
  language      String  @default("fr")
  locale        String  @default("fr")
  timeZone      String  @default("Europe/Paris") @map("time_zone")
  statusMessage String? @map("status_message")
  density       String  @default("comfortable")
  contrast      String  @default("default")
  soundEnabled  Boolean @default(true) @map("sound_enabled")
  secureSession Boolean @default(true) @map("secure_session")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model NotificationPreference {
  id                          String   @id @default(uuid())
  userId                      String   @unique @map("user_id")
  directMessageNotifications  Boolean  @default(true) @map("direct_message_notifications")
  mentionNotifications        Boolean  @default(true) @map("mention_notifications")
  channelMessageNotifications Boolean  @default(true) @map("channel_message_notifications")
  meetingReminders            Boolean  @default(true) @map("meeting_reminders")
  callNotifications           Boolean  @default(true) @map("call_notifications")
  emailNotifications          Boolean  @default(true) @map("email_notifications")
  soundEnabled                Boolean  @default(true) @map("sound_enabled")
  desktopNotifications        Boolean  @default(true) @map("desktop_notifications")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")
  user                        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model LocalCredential {
  id                String   @id @default(uuid())
  userId            String   @unique @map("user_id")
  passwordHash      String   @map("password_hash")
  passwordAlgorithm String   @map("password_algorithm")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("local_credentials")
}

model AuthAccount {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  provider          String
  providerAccountId String    @map("provider_account_id")
  email             String?
  accessToken       String?   @map("access_token")
  refreshToken      String?   @map("refresh_token")
  scopes            String[]  @default([])
  tokenExpiresAt    DateTime? @map("token_expires_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId, provider])
  @@map("auth_accounts")
}

model AuthSession {
  id                   String    @id @default(uuid())
  userId               String    @map("user_id")
  tokenHash            String    @unique @map("token_hash")
  workspaceId          String?   @map("workspace_id")
  refreshTokenHash     String    @map("refresh_token_hash")
  refreshTokenFamilyId String    @map("refresh_token_family_id")
  userAgent            String?   @map("user_agent")
  ipAddress            String?   @map("ip_address")
  expiresAt            DateTime  @map("expires_at")
  lastUsedAt           DateTime  @map("last_used_at")
  revokedAt            DateTime? @map("revoked_at")
  revocationReason     String?   @map("revocation_reason")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("auth_sessions")
}

model AuthRefreshToken {
  id           String    @id @default(uuid())
  sessionId    String    @map("session_id")
  familyId     String    @map("family_id")
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at")
  usedAt       DateTime? @map("used_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?   @map("replaced_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([sessionId, familyId])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([revokedAt])
  @@map("auth_refresh_tokens")
}

model EmailVerificationToken {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at")
  consumedAt   DateTime? @map("consumed_at")
  lastSentAt   DateTime? @map("last_sent_at")
  requestCount Int       @default(0) @map("request_count")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([consumedAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at")
  consumedAt   DateTime? @map("consumed_at")
  lastSentAt   DateTime? @map("last_sent_at")
  requestCount Int       @default(0) @map("request_count")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([consumedAt])
  @@map("password_reset_tokens")
}

model AuthAuditEvent {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  sessionId   String?  @map("session_id")
  workspaceId String?  @map("workspace_id")
  eventType   String   @map("event_type")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  metadata    Json?    @map("metadata")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([sessionId])
  @@index([eventType])
  @@map("auth_audit_events")
}

model Workspace {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  description String?
  visibility  String      @default("private")
  ownerId     String      @map("owner_id")
  archivedAt  DateTime?   @map("archived_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  owner       User        @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members     WorkspaceMember[]
  ssoConfig   WorkspaceSSOConfig?
  contactGroups ContactGroup[]
  files       FileItem[]
  integrations Integration[]
  activities  ActivityItem[]

  @@index([ownerId])
  @@index([archivedAt])
  @@map("workspaces")
}

model WorkspaceSSOConfig {
  id                String   @id @default(uuid())
  workspaceId       String   @unique @map("workspace_id")
  provider          String   @default("oidc")
  enabled           Boolean  @default(false)
  enforceSso        Boolean  @default(false) @map("enforce_sso")
  allowPasswordAuth Boolean  @default(true) @map("allow_password_auth")
  autoProvision     Boolean  @default(true) @map("auto_provision")
  allowIdpInitiated Boolean  @default(false) @map("allow_idp_initiated")
  domainHint        String?  @map("domain_hint")
  issuerUrl         String?  @map("issuer_url")
  ssoUrl            String?  @map("sso_url")
  entityId          String?  @map("entity_id")
  clientId          String?  @map("client_id")
  clientSecret      String?  @map("client_secret")
  certificate       String?
  allowedDomains    Json?    @map("allowed_domains")
  defaultRole       String   @default("member") @map("default_role")
  attributeMapping  Json?    @map("attribute_mapping")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_sso_configs")
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  userId      String    @map("user_id")
  role        String
  joinedAt    DateTime  @map("joined_at")
  lastSeenAt  DateTime? @map("last_seen_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model Contact {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  email       String    @map("email")
  displayName String    @map("display_name")
  avatarUrl   String?   @map("avatar_url")
  phone       String?
  company     String?
  jobTitle    String?   @map("job_title")
  isFavorite  Boolean   @default(false) @map("is_favorite")
  notes       String?
  tags        String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  user        User      @relation("ContactOwner", fields: [userId], references: [id], onDelete: Cascade)
  groups      ContactGroupMember[]

  @@index([userId, displayName])
  @@map("contacts")
}

model ContactGroup {
  id          String               @id @default(uuid())
  workspaceId String               @map("workspace_id")
  name        String
  description String?
  color       String?
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts    ContactGroupMember[]

  @@unique([workspaceId, name])
  @@map("contact_groups")
}

model ContactGroupMember {
  id        String        @id @default(uuid())
  groupId   String        @map("group_id")
  contactId String        @map("contact_id")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  group     ContactGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  contact   Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([groupId, contactId])
  @@index([contactId])
  @@map("contact_group_members")
}

model FamilyMember {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  email        String    @map("email")
  displayName  String    @map("display_name")
  role         String
  status       String
  invitedBy    String    @map("invited_by")
  invitedAt    DateTime  @map("invited_at")
  joinedAt     DateTime? @map("joined_at")
  avatarUrl    String?   @map("avatar_url")
  phone        String?
  relationship String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  user            User      @relation("FamilyMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedByUser   User?     @relation("FamilyMemberInviter", fields: [invitedBy], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([email])
  @@map("family_members")
}

model Invitation {
  id         String    @id @default(uuid())
  email      String    @map("email")
  token      String    @unique
  type       String
  role       String
  message    String?
  status     String
  invitedBy  String    @map("invited_by")
  targetId   String?   @map("target_id")
  acceptedAt DateTime? @map("accepted_at")
  expiresAt  DateTime  @map("expires_at")
  metadata   String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  sender     User      @relation("InvitationSender", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([expiresAt])
  @@map("invitations")
}

model FileItem {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  workspaceId  String?  @map("workspace_id")
  parentId     String?  @map("parent_id")
  name         String
  path         String   @map("path")
  type         String   @default("file")
  mimeType     String?  @map("mime_type")
  size         BigInt   @default(0)
  extension    String?
  hash         String?
  url          String?
  thumbnailUrl String?  @map("thumbnail_url")
  isFavorite   Boolean  @default(false) @map("is_favorite")
  isPublic     Boolean  @default(false) @map("is_public")
  isShared     Boolean  @default(false) @map("is_shared")
  sharedWith   String?  @map("shared_with")
  permissions  String?  @map("permissions")
  description  String?
  tags         String?
  uploadStatus String?  @map("upload_status")
  uploadedBy   String?  @map("uploaded_by")
  version      Int      @default(1)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, path])
  @@index([workspaceId])
  @@index([parentId])
  @@map("file_items")
}

model BillingInfo {
  id               String    @id @default(uuid())
  userId           String    @unique @map("user_id")
  customerId       String?   @map("customer_id")
  paymentMethodId  String?   @map("payment_method_id")
  paymentMethod    String?   @map("payment_method")
  billingEmail     String    @map("billing_email")
  billingAddress   String?   @map("billing_address")
  taxId            String?   @map("tax_id")
  currency         String    @default("EUR")
  nextBillingDate  DateTime? @map("next_billing_date")
  lastPaymentDate  DateTime? @map("last_payment_date")
  paymentStatus    String?   @map("payment_status")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("billing_infos")
}

model Subscription {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  planId         String    @map("plan_id")
  planName       String    @map("plan_name")
  status         String
  amount         Float
  currency       String
  interval       String
  startDate      DateTime  @map("start_date")
  endDate        DateTime? @map("end_date")
  cancelAt       DateTime? @map("cancel_at")
  canceledAt     DateTime? @map("canceled_at")
  trialStart     DateTime? @map("trial_start")
  trialEnd       DateTime? @map("trial_end")
  features       String?
  metadata       String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model Transaction {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  subscriptionId String?   @map("subscription_id")
  type           String
  amount         Float
  currency       String
  description    String
  status         String
  date           DateTime  @map("date")
  invoiceId      String?   @map("invoice_id")
  invoiceUrl     String?   @map("invoice_url")
  paymentId      String?   @map("payment_id")
  gateway        String?
  gatewayData    String?   @map("gateway_data")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([subscriptionId])
  @@map("transactions")
}

model PrivacySettings {
  id              String @id @default(uuid())
  userId          String @unique @map("user_id")
  dataProcessing  Boolean @default(true) @map("data_processing")
  marketingEmails Boolean @default(true) @map("marketing_emails")
  analytics       Boolean @default(true)
  publicProfile   Boolean @default(false) @map("public_profile")
  searchable      Boolean @default(true)
  showOnlineStatus Boolean @default(true) @map("show_online_status")
  dataRetention   String? @map("data_retention")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("privacy_settings")
}

model Device {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  sessionId      String?  @map("session_id")
  type           String
  os             String   @map("os")
  osVersion      String?  @map("os_version")
  browser        String?
  browserVersion String?  @map("browser_version")
  deviceModel    String?  @map("device_model")
  manufacturer   String?
  ipAddress      String   @map("ip_address")
  userAgent      String   @map("user_agent")
  location       String?
  country        String?
  city           String?
  lastActive     DateTime @map("last_active")
  isCurrent      Boolean  @default(false) @map("is_current")
  isTrusted      Boolean  @default(false) @map("is_trusted")
  pushToken      String?  @map("push_token")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@map("devices")
}

model LoginHistory {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  sessionId     String?  @map("session_id")
  timestamp     DateTime @map("timestamp")
  ipAddress     String   @map("ip_address")
  location      String?
  country       String?
  city          String?
  deviceType    String   @map("device_type")
  browser       String?
  os            String?
  userAgent     String?  @map("user_agent")
  status        String
  failureReason String?  @map("failure_reason")
  twoFaUsed     Boolean  @default(false) @map("two_fa_used")
  twoFaMethod   String?  @map("two_fa_method")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@map("login_histories")
}

model ActivityItem {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  workspaceId String?  @map("workspace_id")
  type        String
  entityId    String   @map("entity_id")
  title       String
  message     String
  icon        String?
  url         String?
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([workspaceId])
  @@map("activity_items")
}

model Integration {
  id            String   @id @default(uuid())
  workspaceId   String   @map("workspace_id")
  provider      String
  name          String
  status        String
  configuration Json?
  createdById   String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, provider])
  @@map("integrations")
}
